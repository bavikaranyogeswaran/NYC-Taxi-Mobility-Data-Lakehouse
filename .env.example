# Copy this file to .env — values below match the local Docker stack.
# For production, replace every value with a real secret.
# .env is gitignored — never commit it.

# ── MinIO / S3-compatible Object Storage ──────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── PostgreSQL (admin superuser) ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Airflow metadata DB user (created by postgres-init.sh) ───────────────────
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow

# ── FastAPI / pipeline scripts (lakehouse app user) ───────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=lakehouse
PG_USER=lakehouse
PG_PASS=lakehouse

# ── Airflow Web UI admin ───────────────────────────────────────────────────────
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
_AIRFLOW_WWW_USER_EMAIL=admin@lakehouse.local
