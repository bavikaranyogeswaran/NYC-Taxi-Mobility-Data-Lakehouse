# Copy this file to .env — values below match the local Docker stack.
# For production, replace every value with a real secret.
# .env is gitignored — never commit it.

# ── MinIO / S3-compatible Object Storage ──────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
MINIO_ENDPOINT=http://127.0.0.1:9000

# ── PostgreSQL (admin / Airflow metadata DB) ──────────────────────────────────
POSTGRES_HOST=127.0.0.1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── FastAPI / pipeline scripts (lakehouse app user) ───────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=lakehouse
PG_USER=lakehouse
PG_PASS=lakehouse

# ── Airflow Admin ─────────────────────────────────────────────────────────────
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
_AIRFLOW_WWW_USER_EMAIL=admin@lakehouse.local
