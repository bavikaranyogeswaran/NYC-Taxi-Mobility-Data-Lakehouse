# Copy this file to .env and fill in every <change-me>.
#
# LOCAL DEV (Docker Compose stack):
#   MinIO:       pick any username + password — e.g. minioadmin / minioadmin
#   Postgres:    any password — e.g. lakehousedev
#   Airflow UI:  choose a real password — never use 'admin'
#   Fernet key:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   Webserver key: python -c "import secrets; print(secrets.token_hex(32))"
#
# PRODUCTION: use a secrets manager (Vault, AWS Secrets Manager, GitHub Secrets).
# .env is gitignored — never commit it.

# ── MinIO / S3-compatible Object Storage ──────────────────────────────────────
AWS_ACCESS_KEY_ID=<change-me>
AWS_SECRET_ACCESS_KEY=<change-me>
AWS_DEFAULT_REGION=us-east-1
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ROOT_USER=<change-me>
MINIO_ROOT_PASSWORD=<change-me>

# ── PostgreSQL (admin superuser) ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<change-me>

# ── Airflow metadata DB user (created by postgres-init.sh) ───────────────────
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=<change-me>

# ── FastAPI / pipeline scripts (lakehouse app user) ───────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=lakehouse
PG_USER=lakehouse
PG_PASS=<change-me>

# ── Airflow Web UI admin ───────────────────────────────────────────────────────
_AIRFLOW_WWW_USER_USERNAME=<change-me>
_AIRFLOW_WWW_USER_PASSWORD=<change-me>
_AIRFLOW_WWW_USER_EMAIL=<change-me>

# ── Airflow security keys (REQUIRED — generate before first run) ───────────────
# Fernet key encrypts DAG connection passwords at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=<change-me>
# Flask session signing key for the Airflow webserver.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=<change-me>
